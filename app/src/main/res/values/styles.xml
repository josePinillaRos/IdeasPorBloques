<resources>
    <style name="Widget.Ideas.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@android:color/transparent</item>
        <item name="titleTextColor">@color/brand_text</item>
        <item name="subtitleTextColor">@color/brand_text_muted</item>
        <item name="navigationIconTint">@color/brand_text</item>
    </style>

    <style name="Widget.Ideas.FeatureCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/brand_surface</item>
        <item name="cardCornerRadius">28dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/brand_outline_soft</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.Ideas.ItemCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/brand_surface</item>
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/brand_outline_soft</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:foreground">?attr/selectableItemBackground</item>
    </style>

    <style name="Widget.Ideas.Badge" parent="">
        <item name="android:textColor">@color/brand_on_primary_container</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">12sp</item>
        <item name="android:paddingLeft">12dp</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingRight">12dp</item>
        <item name="android:paddingBottom">8dp</item>
        <item name="android:background">@drawable/bg_badge</item>
    </style>

    <style name="Widget.Ideas.EmptyIconCard" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/brand_surface_alt</item>
        <item name="cardCornerRadius">18dp</item>
        <item name="cardElevation">0dp</item>
    </style>

    <style name="ThemeOverlay.Ideas.Dialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorSurface">@color/brand_surface</item>
        <item name="android:windowBackground">@drawable/bg_dialog_surface</item>
        <item name="materialAlertDialogBodyTextStyle">@style/TextAppearance.Material3.BodyMedium</item>
    </style>
</resources>
